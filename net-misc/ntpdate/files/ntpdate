# $Header: Sync current time using NTP$

depend() {
  after dns dhcpcd net
  need network-online
}

start() {
  local server=${NTP_SERVER:-time.nist.gov}

  ebegin "Syncing time with ${server}"
  netdate -l 0 "${server}" > /dev/null
  eend ${?}
}
