# $Header: Sync current time using NTP$

depend() {
  after dns dhcpcd net
  need network-online
}

start() {
  local server=${NTP_SERVER:-pool.ntp.org}

  ebegin "Syncing time with ${server}"
  chronyd -q "server ${server} iburst" > /dev/null
  eend ${?}
}
