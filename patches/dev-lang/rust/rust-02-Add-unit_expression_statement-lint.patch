diff --git a/src/tools/clippy/clippy_lints/src/unit_expression_statement.rs b/src/tools/clippy/clippy_lints/src/unit_expression_statement.rs
new file mode 100644
index 000000..07ca9a
--- /dev/null
+++ b/src/tools/clippy/clippy_lints/src/unit_expression_statement.rs
@@ -0,0 +1,55 @@
+use clippy_utils::diagnostics::span_lint_and_sugg;
+use rustc_errors::Applicability;
+use rustc_hir::{ExprKind, Stmt, StmtKind};
+use rustc_lint::{LateContext, LateLintPass};
+use rustc_session::declare_lint_pass;
+
+declare_clippy_lint! {
+    /// ### What it does
+    /// Checks for expression statements that evaluate to `()` without an
+    /// explicit `let () = ...;` binding.
+    ///
+    /// ### Why restrict this?
+    /// Wrapping a unit-returning call in `let () = expr;` makes the unit return
+    /// type explicit in the source. If the function signature later changes to
+    /// return a non-unit type, this pattern causes a compile error at the call
+    /// site rather than silently discarding the new return value.
+    ///
+    /// ### Example
+    /// ```no_run
+    /// fn do_something() {}
+    /// do_something();
+    /// ```
+    /// Use instead:
+    /// ```no_run
+    /// fn do_something() {}
+    /// let () = do_something();
+    /// ```
+    #[clippy::version = "1.96.0"]
+    pub UNIT_EXPRESSION_STATEMENT,
+    restriction,
+    "expression statement returning `()` without an explicit `let () = ...` binding",
+    @eval_always = true
+}
+
+declare_lint_pass!(UnitExpressionStatement => [UNIT_EXPRESSION_STATEMENT]);
+
+impl<'tcx> LateLintPass<'tcx> for UnitExpressionStatement {
+    fn check_stmt(&mut self, cx: &LateContext<'tcx>, stmt: &'tcx Stmt<'tcx>) {
+        if let StmtKind::Semi(expr) = stmt.kind
+            && !stmt.span.from_expansion()
+            && matches!(expr.kind, ExprKind::Call(..) | ExprKind::MethodCall(..))
+            && cx.typeck_results().expr_ty(expr).is_unit()
+        {
+            span_lint_and_sugg(
+                cx,
+                UNIT_EXPRESSION_STATEMENT,
+                stmt.span.shrink_to_lo(),
+                "unit-returning expression statement with implicit `()`",
+                "bind the unit value explicitly",
+                "let () = ".to_string(),
+                Applicability::MachineApplicable,
+            );
+        }
+    }
+}
diff --git a/src/tools/clippy/tests/ui/unit_expression_statement.fixed b/src/tools/clippy/tests/ui/unit_expression_statement.fixed
new file mode 100644
index 000000..d49566e
--- /dev/null
+++ b/src/tools/clippy/tests/ui/unit_expression_statement.fixed
@@ -0,0 +1,81 @@
+#![warn(clippy::unit_expression_statement)]
+#![allow(
+    clippy::let_unit_value,
+    clippy::match_single_binding,
+    clippy::needless_ifs,
+    clippy::no_effect,
+    clippy::unnecessary_operation,
+    dropping_copy_types,
+    unused_must_use
+)]
+
+fn unit_fn() {}
+
+fn unit_fn_with_args(_a: &str) {}
+
+fn fallible() -> Result<(), String> {
+    Ok(())
+}
+
+fn returns_i32() -> i32 {
+    42
+}
+
+// Should lint
+fn should_lint() {
+    let () = unit_fn();
+    //~^ unit_expression_statement
+    let () = unit_fn_with_args("hello");
+    //~^ unit_expression_statement
+    let () = fallible().unwrap();
+    //~^ unit_expression_statement
+
+    let mut v = vec![1, 2, 3];
+    let () = v.push(4);
+    //~^ unit_expression_statement
+    let () = v.clear();
+    //~^ unit_expression_statement
+
+    let () = drop(42);
+    //~^ unit_expression_statement
+}
+
+// Should not lint
+fn should_not_lint() {
+    // Already explicit
+    let () = unit_fn();
+
+    // Non-unit return type (returns i32)
+    returns_i32();
+
+    // Unit literal
+    ();
+
+    // Assignments
+    let mut x = 5;
+    x = 10;
+    x += 1;
+    let _ = x;
+
+    // Control flow constructs (not Call/MethodCall)
+    if true {}
+    match 0 {
+        _ => {},
+    }
+    for _ in 0..3 {}
+    while false {}
+
+    // Macro expansion
+    println!("hello");
+    eprintln!("hello");
+
+    // Block expression
+    {}
+}
+
+#[allow(clippy::unit_expression_statement)]
+fn allowed() {
+    unit_fn(); // should be suppressed
+}
+
+fn main() {}
