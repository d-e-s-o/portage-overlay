diff --git a/src/tools/clippy/tests/ui/let_with_type_annotation.rs b/src/tools/clippy/tests/ui/let_with_type_annotation.rs
new file mode 100644
index 000000..b68fd6
--- /dev/null
+++ b/src/tools/clippy/tests/ui/let_with_type_annotation.rs
@@ -0,0 +1,44 @@
+#![warn(clippy::let_with_type_annotation)]
+#![allow(clippy::useless_vec, clippy::needless_late_init)]
+
+// Should lint
+fn should_lint() {
+    let x: u32 = 42;
+    //~^ let_with_type_annotation
+    let s: String = String::new();
+    //~^ let_with_type_annotation
+    let v: Vec<i32> = vec![1];
+    //~^ let_with_type_annotation
+    let b: bool = true;
+    //~^ let_with_type_annotation
+    let r: &str = "hello";
+    //~^ let_with_type_annotation
+
+    // With underscore type (still explicit annotation)
+    let _x: i64 = 0;
+    //~^ let_with_type_annotation
+
+    // Without initializer
+    let _y: u32;
+    //~^ let_with_type_annotation
+}
+
+// Should not lint
+fn should_not_lint() {
+    let x = 42u32;
+    let s = String::new();
+    let v = vec![1i32];
+    let b = true;
+    let r = "hello";
+
+    // No type annotation, no init
+    let _y;
+    _y = 1;
+}
+
+#[allow(clippy::let_with_type_annotation)]
+fn allowed() {
+    let x: u32 = 42; // should be suppressed
+}
+
+fn main() {}
