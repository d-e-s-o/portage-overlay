index 000000..5d6988
--- /dev/null
+++ b/src/tools/clippy/clippy_lints/src/let_with_type_annotation.rs
@@ -0,0 +1,55 @@
+use clippy_utils::diagnostics::span_lint_and_help;
+use rustc_ast::Local;
+use rustc_lint::{EarlyContext, EarlyLintPass, LintContext};
+use rustc_session::declare_lint_pass;
+
+declare_clippy_lint! {
+    /// ### What it does
+    /// Warns when a `let` binding has an explicit type annotation.
+    ///
+    /// ### Why restrict this?
+    /// Explicit type annotations on `let` bindings can often be avoided by
+    /// adjusting the right-hand side or surrounding code so that the type is
+    /// inferred. Omitting annotations reduces noise and makes code easier to
+    /// refactor.
+    ///
+    /// ### Known problems
+    /// Sometimes type annotations are necessary for disambiguation (e.g.,
+    /// `let x: Vec<_> = iter.collect()`), or when there is no initializer.
+    /// In those cases, allow this lint on a case-by-case basis.
+    ///
+    /// ### Example
+    /// ```rust,ignore
+    /// let x: u32 = 42;
+    /// ```
+    /// Use instead:
+    /// ```rust,ignore
+    /// let x = 42u32;
+    /// ```
+    #[clippy::version = "1.96.0"]
+    pub LET_WITH_TYPE_ANNOTATION,
+    restriction,
+    "explicit type annotation on a `let` binding",
+    @eval_always = true
+}
+
+declare_lint_pass!(LetWithTypeAnnotation => [LET_WITH_TYPE_ANNOTATION]);
+
+impl EarlyLintPass for LetWithTypeAnnotation {
+    fn check_local(&mut self, cx: &EarlyContext<'_>, local: &Local) {
+        if let Some(ty) = &local.ty
+            && local.span.eq_ctxt(ty.span)
+            && let sm = cx.sess().source_map()
+            && !local.span.in_external_macro(sm)
+        {
+            span_lint_and_help(
+                cx,
+                LET_WITH_TYPE_ANNOTATION,
+                local.span,
+                "explicit type annotation on `let` binding",
+                None,
+                "consider removing the type annotation and adjusting the expression or surrounding code so the type can be inferred",
+            );
+        }
+    }
+}
